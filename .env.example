# === P4 Quality Repair Tool – Environment Variables ===
# Copy to .env and fill in real values:  cp .env.example .env

# Data directory for session storage
DATA_DIR=data

# OpenAI (required for LLM repair in Sprint 2)
OPENAI_API_KEY=your-sk-proj-key-here
OPENAI_MODEL=gpt-4o-mini
TOKEN_BUDGET=20000
MAX_REPAIR_ISSUES=10

# Storage backend (local only for PoC)
STORAGE_BACKEND=local

# Ollama (local LLM)
# If running Ollama on the host and this tool in Docker, use:
OLLAMA_BASE_URL=http://host.docker.internal:11434
#OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# Log level
LOG_LEVEL=INFO
